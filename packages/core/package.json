{
  "name": "dc2mermaid-core",
  "version": "0.2.0",
  "description": "Core library for docker-compose-to-mermaid",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/TamirTapiro/docker-compose-to-mermaid.git",
    "directory": "packages/core"
  },
  "keywords": [
    "docker-compose",
    "mermaid",
    "diagram",
    "architecture",
    "visualization"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "files": [
    "dist/"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist/",
    "test": "vitest run"
  },
  "dependencies": {
    "yaml": "^2.4",
    "zod": "^4.3"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "vitest": "^4.1"
  }
}

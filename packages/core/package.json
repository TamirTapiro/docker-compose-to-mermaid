{
  "name": "@dc2mermaid/core",
  "version": "0.0.1",
  "description": "Core library for docker-compose-to-mermaid",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist/"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist/",
    "test": "vitest run"
  },
  "dependencies": {
    "yaml": "^2.4",
    "zod": "^3.23"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "vitest": "^1.6"
  }
}

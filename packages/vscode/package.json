{
  "name": "dc2mermaid-vscode",
  "displayName": "Docker Compose to Mermaid",
  "description": "Live Mermaid architecture diagram preview for docker-compose files",
  "version": "0.0.1",
  "publisher": "TamirTapiro",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/TamirTapiro/docker-compose-to-mermaid.git",
    "directory": "packages/vscode"
  },
  "keywords": [
    "docker-compose",
    "mermaid",
    "diagram",
    "architecture",
    "visualization"
  ],
  "icon": "icon.png",
  "galleryBanner": {
    "color": "#1A1A2E",
    "theme": "dark"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Visualization",
    "Other"
  ],
  "activationEvents": [
    "workspaceContains:**/docker-compose*.yml"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "dc2mermaid.generateDiagram",
        "title": "Docker Compose: Generate Architecture Diagram"
      }
    ]
  },
  "scripts": {
    "build": "tsup src/extension.ts --format cjs --dts --out-dir dist --external vscode",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist/"
  },
  "dependencies": {
    "dc2mermaid-core": "workspace:*"
  },
  "devDependencies": {
    "@types/vscode": "^1.85.0",
    "tsup": "^8",
    "typescript": "^5.4"
  }
}
